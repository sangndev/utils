      "types": "./dist/types/index.d.ts"
    }
  },
  "devDependencies": {
    "eslint": "10.1.0",
    "prettier": "3.8.1",
    "rolldown": "^1.0.0-rc.9",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate-types": "tsc -p tsconfig.json",
    "build": "rm -rf /dist && node scripts/build.js && yarn generate-types",
    "test": "node --test"
  }
}
