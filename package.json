{
  "name": "@sangndev/utils",
  "version": "1.0.0",
  "description": "Some helper functions, hooks or even React Component made by sangndev",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "repository": "https://github.com/sangndev/utils",
  "author": "sangndev",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
